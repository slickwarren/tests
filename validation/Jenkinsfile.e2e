#!groovy
/**
 * E2E validation pipeline with infrastructure provisioning.
 *
 * Full-stack pipeline that:
 *   1. Provisions AWS infrastructure via OpenTofu (make backend-s3, workspace-new, infra-up)
 *   2. Deploys a default RKE2 cluster on AWS via qa-infra-automation Makefile (make cluster)
 *   3. Deploys Rancher (make rancher)
 *   4. Generates admin token
 *   5. Triggers downstream test jobs in parallel
 *   6. Tears down infrastructure after tests (or on failure)
 *
 *
 * Consumes shared functions from qa-jenkins-library:
 *   infra.backendS3, infra.workspaceNew, infra.up, infra.cluster, infra.rancher, infra.down
 *   airgap.standardCheckout
 *   infrastructure.parseAndSubstituteVars, infrastructure.writeConfig,
 *   infrastructure.generateWorkspaceName, infrastructure.archiveWorkspaceName,
 *   infrastructure.writeSshKey
 *   property.useWithProperties
 *
 * Admin token generation uses a direct ansible-playbook call inside
 * rancher-go-test:latest (no make target for this yet — TODO: add make token).
 */

def libraryBranch = env.QA_JENKINS_LIBRARY_BRANCH ?: 'main'
library "qa-jenkins-library@${libraryBranch}"

/**
 * Shared teardown helper: re-renders tfvars from params, tears down tofu workspace
 * via make infra-down AUTO_APPROVE=yes.
 * Sets env.INFRA_CLEANED to 'true' on success.
 */
def destroyInfrastructure(String reason) {
    def wsName = ''
    try {
        if (fileExists('workspace_name.txt')) {
            wsName = readFile('workspace_name.txt')?.trim()
        }
    } catch (e) {
        echo "Could not read workspace_name.txt: ${e.message}"
    }

    if (!wsName || !env.INFRA_DIR || env.INFRA_CLEANED == 'true') {
        echo "Skipping teardown (${reason}): no workspace, no infra dir, or already cleaned"
        return
    }

    try {
        property.useWithProperties([
            'AWS_ACCESS_KEY_ID',
            'AWS_SECRET_ACCESS_KEY',
            'AWS_SSH_PEM_KEY_NAME'
        ]) {
            // Re-render terraform.tfvars so tofu destroy can access AWS state
            def tofuDir = "${env.INFRA_DIR}/tofu/aws/modules/cluster_nodes"
            def terraformConfig = infrastructure.parseAndSubstituteVars(
                content: params.TERRAFORM_CONFIG,
                envVars: [
                    'AWS_ACCESS_KEY_ID':     env.AWS_ACCESS_KEY_ID,
                    'AWS_SECRET_ACCESS_KEY': env.AWS_SECRET_ACCESS_KEY,
                    'HOSTNAME_PREFIX':       params.HOSTNAME_PREFIX,
                    'AWS_SSH_PEM_KEY_NAME':  env.AWS_SSH_PEM_KEY_NAME
                ]
            )
            infrastructure.writeConfig(
                path:    "${tofuDir}/terraform.tfvars",
                content: terraformConfig
            )
            infra.down(env.INFRA_DIR, wsName)
            env.INFRA_CLEANED = 'true'
        }
    } catch (cleanupErr) {
        echo "Teardown failed (${reason}): ${cleanupErr.message}"
    }
}

pipeline {
    agent any

    options {
        ansiColor('xterm')
        timeout(time: 180, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '30'))
    }

    parameters {
        // ── Repository parameters ──────────────────────────────
        string(
            name: 'QA_JENKINS_LIBRARY_BRANCH',
            defaultValue: 'main',
            description: 'Branch of qa-jenkins-library to use'
        )
        string(
            name: 'TESTS_REPO_URL',
            defaultValue: 'https://github.com/rancher/tests',
            description: 'URL of rancher/tests repository'
        )
        string(
            name: 'TESTS_BRANCH',
            defaultValue: 'main',
            description: 'Branch of rancher/tests repository'
        )
        string(
            name: 'QA_INFRA_REPO_URL',
            defaultValue: 'https://github.com/rancher/qa-infra-automation',
            description: 'URL of qa-infra-automation repository'
        )
        string(
            name: 'QA_INFRA_BRANCH',
            defaultValue: 'main',
            description: 'Branch of qa-infra-automation repository'
        )

        // ── Infrastructure parameters ──────────────────────────
        string(
            name: 'HOSTNAME_PREFIX',
            defaultValue: 'pitdaily',
            description: 'Hostname prefix for *.qa.rancher.space and other AWS resources'
        )
        string(
            name: 'RKE2_VERSION',
            defaultValue: 'v1.35.1+rke2r1',
            description: 'RKE2 version to deploy'
        )
        string(
            name: 'RANCHER_VERSION',
            defaultValue: 'latest',
            description: 'Rancher version to deploy'
        )
        string(
            name: 'RANCHER_IMAGE_TAG',
            defaultValue: 'head',
            description: 'Rancher container image tag (head for dev builds, version tag for stable)'
        )
        string(
            name: 'RANCHER_CHART_REPO_URL',
            defaultValue: 'https://releases.rancher.com/server-charts/latest',
            description: 'Rancher Helm chart repository URL'
        )
        string(
            name: 'PRIVATE_REGISTRY_URL',
            defaultValue: '',
            description: 'Private registry URL (kept for forward compatibility; not wired in default ENV flow)'
        )
        string(
            name: 'PRIVATE_REGISTRY_USERNAME',
            defaultValue: '',
            description: 'Private registry username (kept for forward compatibility)'
        )
        password(
            name: 'PRIVATE_REGISTRY_PASSWORD',
            defaultValue: '',
            description: 'Private registry password (kept for forward compatibility)'
        )
        password(
            name: 'RANCHER_BOOTSTRAP_PASSWORD',
            defaultValue: 'rancherrocks',
            description: 'Rancher bootstrap password for initial setup'
        )
        password(
            name: 'RANCHER_ADMIN_PASSWORD',
            defaultValue: 'rancherrocks',
            description: 'Rancher admin password after bootstrap'
        )
        booleanParam(
            name: 'ENABLE_PRIVATE_REGISTRY',
            defaultValue: false,
            description: 'Enable private registry configuration (kept for forward compatibility; not wired in default ENV flow)'
        )
        booleanParam(
            name: 'DEPLOY_RANCHER',
            defaultValue: true,
            description: 'Deploy Rancher via Helm after RKE2 setup'
        )
        booleanParam(
            name: 'DESTROY_ON_FAILURE',
            defaultValue: true,
            description: 'Tear down infrastructure if pipeline fails'
        )
        booleanParam(
            name: 'DESTROY_AFTER_TESTS',
            defaultValue: true,
            description: 'Tear down infrastructure after tests complete'
        )

        // ── Terraform parameters ───────────────────────────────
        string(
            name: 'S3_BUCKET_NAME',
            defaultValue: 'jenkins-terraform-state-storage',
            description: 'S3 bucket name where Terraform state is stored'
        )
        string(
            name: 'S3_BUCKET_REGION',
            defaultValue: 'us-east-2',
            description: 'AWS region where the S3 bucket is located'
        )
        string(
            name: 'S3_KEY_PREFIX',
            defaultValue: 'terraform.tfstate',
            description: 'S3 key prefix for the Terraform state files'
        )
        text(
            name: 'TERRAFORM_CONFIG',
            description: 'Terraform tfvars for the cluster_nodes module (non-airgap)',
            defaultValue: '''aws_access_key = "${AWS_ACCESS_KEY_ID}"
aws_secret_key = "${AWS_SECRET_ACCESS_KEY}"
aws_ami = "ami-01b0ef1ab7898646f"
instance_type = "t3a.2xlarge"
aws_security_group = ["sg-07a98dc3474d4eb9f"]
aws_subnet = "subnet-0377a1ca391d51cae"
airgap_setup = false
proxy_setup = false
aws_volume_size = 500
aws_volume_type = "gp3"
aws_hostname_prefix = "${HOSTNAME_PREFIX}"
aws_region = "us-west-1"
aws_route53_zone = "qa.rancher.space"
aws_ssh_user = "ec2-user"
aws_vpc = "vpc-081cec85dbe35e9bd"
public_ssh_key = "ssh_public_key.pub"
private_ssh_key = "~/.ssh/\${AWS_SSH_PEM_KEY_NAME}"
nodes = [
    {
        count = 3
        role  = ["etcd", "cp", "worker"]
    },
    {
        count = 1
        role  = ["worker"]
    }
]'''
        )
        text(
            name: 'ANSIBLE_VARIABLES',
            description: 'Ansible group_vars for RKE2 install + Rancher Helm deploy (non-airgap)',
            defaultValue: '''---
kubernetes_version: ${RKE2_VERSION}
cni: calico
kubeconfig_file: "/workspace/qa-infra-automation/ansible/rke2/default/kubeconfig.yaml"
cert_manager_version: "1.17.4"
bootstrap_password: "${RANCHER_BOOTSTRAP_PASSWORD}"
password: "${RANCHER_ADMIN_PASSWORD}"
rancher_version: ${RANCHER_VERSION}
rancher_image_tag: ${RANCHER_IMAGE_TAG}
rancher_chart_repo_url: "${RANCHER_CHART_REPO_URL}"
upgrade_mode: false
rancher_version_upgrade: ">=0.0.0-0"
rancher_image_tag_upgrade: "latest"
rancher_chart_repo_upgrade: "rancher-upgrade"
rancher_chart_upgrade_repo_url: "https://releases.rancher.com/server-charts/alpha"
k8s_upgrade_mode: false
kubernetes_version_upgrade: v1.35.2+rke2r1
server_flags: |
    ingress-controller: traefik'''
        )

        // ── Test parameters ────────────────────────────────────
        text(
            name: 'CATTLE_TEST_CONFIG',
            defaultValue: '''awsNodeTemplate:
    accessKey: ${AWS_ACCESS_KEY_ID}
    ami: ami-0b8e245d9e93c05fa
    blockDurationMinutes: 0
    encryptEbsVolume: false
    httpEndpoint: enabled
    httpTokens: optional
    iamInstanceProfile: EngineeringUsersUS
    insecureTransport: false
    instanceType: t3.xlarge
    keypairName: jenkins-elliptic-validation.pem
    monitoring: false
    privateAddressOnly: false
    region: us-east-2
    requestSpotInstance: true
    retries: 5
    rootSize: 16
    secretKey: ${AWS_SECRET_ACCESS_KEY}
    securityGroup:
    - qa_default_ipv4
    securityGroupReadonly: false
    spotPrice: 0.5
    sshUser: ubuntu
    subnetId: subnet-ee8cac86
    type: amazonec2Config
    useEbsOptimizedInstance: false
    usePrivateAddress: false
    volumeType: gp3
    vpcId: vpc-bfccf4d7
    zone: a
awsMachineConfigs:
    region: us-east-2
    awsMachineConfig:
    - ami: ami-0b8e245d9e93c05fa
      roles: ["etcd","controlplane","worker"]
      instanceType: t3a.xlarge
      retries: "5"
      rootSize: "100"
      securityGroup:
      - qa_default_ipv4
      sshUser: ubuntu
      volumeType: gp3
      vpcId: vpc-bfccf4d7
      zone: a
awsCredentials:
    accessKey: ${AWS_ACCESS_KEY_ID}
    defaultRegion: us-east-2
    secretKey: ${AWS_SECRET_ACCESS_KEY}
awsEC2Configs:
    awsAMI: ami-02ec473a7c3a2db48
    awsAccessKeyID: ${AWS_ACCESS_KEY_ID}
    awsSecretAccessKey: ${AWS_SECRET_ACCESS_KEY}
    region: us-east-2
    awsEC2Config:
    - awsAMI: ami-053835e36b16f97d0
      awsCICDInstanceTag: rancher-validation
      awsIAMProfile: EngineeringUsersUS
      awsSSHKeyName: jenkins-elliptic-validation.pem
      awsSecurityGroups:
      - sg-08e8243a8cfbea8a0 # qa_default_ipv4
      awsUser: ec2-user
      instanceType: t3a.2xlarge
      isWindows: false
      volumeSize: 50
      roles: [etcd, contolplane, worker]
provisioningInput:
    psact: "rancher-privileged"
    cni:
    - calico
    nodeProviders:
    - ec2
    machinePools:
    - machinePoolConfig:
        etcd: true
        controlplane: false
        worker: false
        quantity: 1
    - machinePoolConfig:
        etcd: false
        controlplane: true
        worker: false
        quantity: 1
    - machinePoolConfig:
        etcd: false
        controlplane: false
        worker: true
        quantity: 1
    nodePools:
    - nodeRoles:
        etcd: true
        controlplane: false
        worker: false
        quantity: 1
    - nodeRoles:
        etcd: false
        controlplane: true
        worker: false
        quantity: 1
    - nodeRoles:
        etcd: false
        controlplane: false
        worker: true
        quantity: 1
    providers:
    - aws
corralRancherHA:
    name: rancherha
sshPath:
    sshPath: "/root/go/src/github.com/rancher/tests/validation/.ssh"
flags:
    desiredflags: InstallRancher|Short
qaInfraAutomation:
    ansible:
        configPath: ansible/rancher/downstream/custom_cluster/ansible.cfg
    aws:
        accessKey: ${AWS_ACCESS_KEY_ID}
        airgapSetup: false
        ami: ami-05bca07e340ee4f45
        hostnamePrefix: tf-pit-daily
        instanceType: t3a.2xlarge
        nodes:
        - count: 1
          role:
            - etcd
            - cp
            - worker
        proxySetup: false
        region: us-east-2
        route53Zone: qa.rancher.space
        secretKey: ${AWS_SECRET_ACCESS_KEY}
        securityGroups:
            - sg-08e8243a8cfbea8a0
        awsSSHKeyName: "jenkins-elliptic-validation"
        sshUser: ec2-user
        subnet: subnet-ee8cac86
        volumeSize: 50
        volumeType: gp3
        vpc: vpc-bfccf4d7
    customCluster:
        generateName: tf-pit-daily
        harden: true
        isNetworkPolicy: false
        kubernetesVersion: v1.34.4+k3s1
        psa: rancher-privileged
        nodes:
            - count: 1
              role: [etcd, cp, worker]
    repoPath: /infratest
    workspace: tf-pit-daily
rancher:
    host: ${HOSTNAME_PREFIX}.qa.rancher.space
    adminPassword: ${ADMIN_PASSWORD}
    insecure: true
    cleanup: false
gitRepo:
    metadata:
        name: "dynamic-test-1"
        namespace: "fleet-default"
    spec:
        repo: https://github.com/rancher/fleet-examples
        branch: master
        paths:
        - simple''',
            description: 'Test configuration YAML (cattle-config). Token will be injected automatically.'
        )
        booleanParam(
            name: 'BUILD_DOWNSTREAM_CLUSTER',
            defaultValue: true,
            description: 'Provision a downstream Kubernetes cluster through Rancher via tofu/rancher/cluster module'
        )
        text(
            name: 'DOWNSTREAM_CLUSTER_CONFIG',
            description: 'Terraform tfvars for the downstream cluster created through Rancher (tofu/rancher/cluster module)',
            defaultValue: '''kubernetes_version = "v1.35.1+rke2r1"
is_network_policy = false
machine_pools = [ {
control_plane_role = true
worker_role = true
etcd_role = true
quantity = 3
} ]
create_new = true
generate_name = "pitdaily-tf"
machine_global_config = {
cni = "calico"
ingress-controller = "traefik"
}
node_config = {
aws_access_key = "\${AWS_ACCESS_KEY_ID}"
aws_secret_key = "\${AWS_SECRET_ACCESS_KEY}"
access_key     = "\${AWS_ACCESS_KEY_ID}"
secret_key     = "\${AWS_SECRET_ACCESS_KEY}"

aws_ami = "ami-01b0ef1ab7898646f"
aws_ssh_user = "ec2-user"
aws_instance_type = "t3a.2xlarge"
aws_security_group = ["allopen-dualstack"]

aws_subnet = "subnet-0377a1ca391d51cae"
aws_availability_zone = "b"
aws_vpc = "vpc-081cec85dbe35e9bd"
aws_region    = "us-west-1"
aws_volume_size   = 50
aws_volume_type   = "gp3"
}

cloud_provider = "aws"
insecure = true'''
        )
        booleanParam(
            name: 'REPORT_ARTIFACTS',
            defaultValue: true,
            description: 'Archive test logs and results as build artifacts'
        )

        // ── Downstream job parameters ─────────────────────────
        string(
            name: 'INDIVIDUAL_JOB',
            defaultValue: 'go-pit-daily-individual-updated-job',
            description: 'Name of the downstream Jenkins job that runs individual Go test suites'
        )
        string(
            name: 'TEST_PACKAGE',
            defaultValue: './validation/...',
            description: 'Go test package path passed to the downstream job'
        )
        string(
            name: 'GOTEST_TESTCASE_PROVISIONING',
            defaultValue: '',
            description: 'Go test case regex for provisioning tests (-run flag). Empty = all provisioning tests.'
        )
        string(
            name: 'GOTEST_TESTCASE_VALIDATION',
            defaultValue: '',
            description: 'Go test case regex for validation tests (-run flag). Empty = all validation tests.'
        )
        string(
            name: 'PROVISIONING_TAGS',
            defaultValue: '',
            description: 'Go build tags for provisioning tests. Triggers test-provisioning downstream job when set.'
        )
        string(
            name: 'VALIDATION_TEST_TAGS',
            defaultValue: 'pit.daily',
            description: 'Go build tags for validation tests. Triggers test-validation downstream job when set.'
        )
        string(
            name: 'TEST_TIMEOUT',
            defaultValue: '60m',
            description: 'Timeout for downstream test jobs'
        )
        string(
            name: 'QASE_REPORTER_SCRIPT',
            defaultValue: 'build_qase_reporter_v2.sh',
            description: 'Qase reporter script name in pipeline/scripts/'
        )
    }

    environment {
        WORKSPACE_NAME = ''
        INFRA_CLEANED  = 'false'
    }

    stages {
        stage('Checkout') {
            steps {
                script {
                    def dirs = airgap.standardCheckout(
                        testsRepo: [url: params.TESTS_REPO_URL, branch: params.TESTS_BRANCH],
                        infraRepo: [url: params.QA_INFRA_REPO_URL, branch: params.QA_INFRA_BRANCH]
                    )
                    env.TESTS_DIR = dirs.testsDir
                    env.INFRA_DIR = dirs.infraDir

                    def hostnamePrefix = params.HOSTNAME_PREFIX ?: 'unknown'
                    currentBuild.displayName = "#${env.BUILD_NUMBER} - ${hostnamePrefix}"
                    currentBuild.description = "Provisioning infrastructure for ${hostnamePrefix}"
                }
            }
        }

        stage('Build Docker Images') {
            steps {
                // rancher-infra-tools:latest — used by make.groovy / infra.* for all make targets
                sh "docker build --no-cache --platform linux/amd64 -t rancher-infra-tools:latest -f ${env.TESTS_DIR}/validation/pipeline/Dockerfile.infra ."
                // rancher-go-test:latest — used for qase binary build and admin-token playbook
                sh "docker build --no-cache --platform linux/amd64 -t rancher-go-test:latest -f ${env.TESTS_DIR}/validation/pipeline/Dockerfile.airgap-go-tests ."
            }
        }

        stage('Setup Tools') {
            steps {
                sh 'wget -qO ./yq https://github.com/mikefarah/yq/releases/latest/download/yq_linux_amd64 || true'
                sh 'chmod +x ./yq || true'
            }
        }

        stage('Provision Infrastructure') {
            steps {
                script {
                    property.useWithProperties([
                        'AWS_ACCESS_KEY_ID',
                        'AWS_SECRET_ACCESS_KEY',
                        'AWS_SSH_PEM_KEY',
                        'AWS_SSH_PEM_KEY_NAME',
                        'PRIVATE_REGISTRY_URL',
                        'PRIVATE_REGISTRY_USERNAME',
                        'PRIVATE_REGISTRY_PASSWORD'
                    ]) {
                        def ansiblePath = "${env.INFRA_DIR}/ansible/rke2/default"
                        def tofuModulePath = "${env.INFRA_DIR}/tofu/aws/modules/cluster_nodes"
                        def workspaceName = ''

                        // ── SSH key setup ──────────────────────────────────
                        stage('Configure SSH Key') {
                            infrastructure.writeSshKey(
                                keyContent: env.AWS_SSH_PEM_KEY,
                                keyName:    env.AWS_SSH_PEM_KEY_NAME,
                                dir:        '.ssh'
                            )
                            // Copy public key into the tofu module directory so
                            // tofu's file() function can read it (restricted to
                            // the module directory tree).
                            sh "cp .ssh/*.pub ${tofuModulePath}/ssh_public_key.pub"
                        }

                        // ── Render terraform.tfvars ────────────────────────
                        // Must exist before any make target runs (check-tofu-dir validates it).
                        stage('Configure Tofu Variables') {
                            def terraformConfig = infrastructure.parseAndSubstituteVars(
                                content: params.TERRAFORM_CONFIG,
                                envVars: [
                                    'AWS_ACCESS_KEY_ID':     env.AWS_ACCESS_KEY_ID,
                                    'AWS_SECRET_ACCESS_KEY': env.AWS_SECRET_ACCESS_KEY,
                                    'HOSTNAME_PREFIX':       params.HOSTNAME_PREFIX,
                                    'AWS_SSH_PEM_KEY_NAME':  env.AWS_SSH_PEM_KEY_NAME
                                ]
                            )
                            infrastructure.writeConfig(
                                path:    "${tofuModulePath}/terraform.tfvars",
                                content: terraformConfig
                            )
                        }

                        // ── Write group_vars/all.yml ───────────────────────
                        // Must exist before make cluster (make infra-up generates
                        // inventory.yml but not the group_vars subdirectory).
                        stage('Configure Ansible Variables') {
                            sh "mkdir -p ${ansiblePath}/inventory/group_vars"

                            // Determine the appropriate Helm chart repository based on RANCHER_VERSION.
                            // If RANCHER_VERSION looks like a stable semver (e.g., 2.13.2 or v2.13.2), use the stable repo.
                            // Otherwise (e.g., latest, alpha, rc), default to the alpha repo.
                            // This can be overridden by explicitly setting RANCHER_CHART_REPO_URL.
                            def defaultChartRepoUrl = 'https://releases.rancher.com/server-charts/alpha'
                            if (params.RANCHER_VERSION && params.RANCHER_VERSION ==~ /v?\d+\.\d+\.\d+/) {
                                defaultChartRepoUrl = 'https://releases.rancher.com/server-charts/stable'
                            }
                            def rancherChartRepoUrlParam = params.RANCHER_CHART_REPO_URL ?: defaultChartRepoUrl

                            def ansibleVars = infrastructure.parseAndSubstituteVars(
                                content: params.ANSIBLE_VARIABLES,
                                envVars: [
                                    'RKE2_VERSION':              params.RKE2_VERSION,
                                    'RANCHER_BOOTSTRAP_PASSWORD': params.RANCHER_BOOTSTRAP_PASSWORD ?: 'rancherrocks',
                                    'RANCHER_ADMIN_PASSWORD':     params.RANCHER_ADMIN_PASSWORD ?: 'rancherrocks',
                                    'RANCHER_VERSION':           params.RANCHER_VERSION,
                                    'RANCHER_IMAGE_TAG':         params.RANCHER_IMAGE_TAG ?: 'head',
                                    'RANCHER_CHART_REPO_URL':    rancherChartRepoUrlParam
                                ]
                            )

                            def rancherVars = infrastructure.parseAndSubstituteVars(
                                content: '''deploy_rancher: ${DEPLOY_RANCHER_ANSIBLE}
install_helm: true
rancher_hostname: "${HOSTNAME_PREFIX}.qa.rancher.space"
rancher_bootstrap_password: "${RANCHER_BOOTSTRAP_PASSWORD}"
rancher_admin_password: "${RANCHER_ADMIN_PASSWORD}"
rancher_image_tag: ${RANCHER_IMAGE_TAG}
rancher_use_bundled_system_charts: true
''',
                                envVars: [
                                    'DEPLOY_RANCHER_ANSIBLE':      params.DEPLOY_RANCHER ? 'true' : 'false',
                                    'HOSTNAME_PREFIX':            params.HOSTNAME_PREFIX,
                                    'RANCHER_BOOTSTRAP_PASSWORD':  params.RANCHER_BOOTSTRAP_PASSWORD ?: 'rancherrocks',
                                    'RANCHER_ADMIN_PASSWORD':      params.RANCHER_ADMIN_PASSWORD ?: 'rancherrocks',
                                    'RANCHER_IMAGE_TAG':           params.RANCHER_IMAGE_TAG ?: 'head'
                                ]
                            )

                            // Merge ANSIBLE_VARIABLES + Rancher vars into a single group_vars/all.yml
                            infrastructure.writeConfig(
                                path:    "${ansiblePath}/inventory/group_vars/all.yml",
                                content: ansibleVars + '\n' + rancherVars
                            )
                        }

                        // ── Initialize S3 backend ──────────────────────────
                        stage('Initialize Tofu Backend') {
                            infra.backendS3(
                                env.INFRA_DIR,
                                params.S3_BUCKET_NAME,
                                params.S3_KEY_PREFIX,
                                params.S3_BUCKET_REGION
                            )
                        }

                        // ── Create tofu workspace ──────────────────────────
                        stage('Create Workspace') {
                            workspaceName = infrastructure.generateWorkspaceName(
                                prefix:           'jenkins_e2e_workspace',
                                suffix:           params.HOSTNAME_PREFIX,
                                includeTimestamp: false
                            )
                            infra.workspaceNew(env.INFRA_DIR, workspaceName)
                            infrastructure.archiveWorkspaceName(workspaceName: workspaceName)
                            env.WORKSPACE_NAME = workspaceName
                        }

                        // ── Provision infra + generate inventory ───────────
                        stage('Provision Infrastructure') {
                            infra.up(env.INFRA_DIR, workspaceName)
                        }

                        // ── Deploy RKE2 cluster ────────────────────────────
                        stage('Deploy RKE2 Cluster') {
                            infra.cluster(env.INFRA_DIR, workspaceName)
                        }

                        // ── Deploy Rancher ─────────────────────────────────
                        stage('Deploy Rancher') {
                            if (params.DEPLOY_RANCHER) {
                                infra.rancher(env.INFRA_DIR, workspaceName)
                            } else {
                                echo 'Skipping Rancher deployment (DEPLOY_RANCHER not checked)'
                            }
                        }

                        // ── Capture Rancher hostname ───────────────────────
                        stage('Output Infrastructure Details') {
                            // Rancher hostname is deterministically constructed from HOSTNAME_PREFIX
                            // matching the value set in rancherVars (rancher_hostname).
                            // This avoids dependency on Terraform output names that may vary.
                            def rancherHostname = "${params.HOSTNAME_PREFIX}.qa.rancher.space"
                            echo "Rancher Hostname: https://${rancherHostname}"
                            env.RANCHER_HOSTNAME = rancherHostname
                            currentBuild.description = "Testing: https://${rancherHostname} | Workspace: ${workspaceName}"
                        }
                    }
                }
            }
        }

        stage('Create Test Config and Inject Admin Token') {
            when {
                expression { params.CATTLE_TEST_CONFIG?.trim() }
            }
            steps {
                script {
                    // Create cattle-config with variable substitution
                    if (params.CATTLE_TEST_CONFIG?.trim()) {
                        // Resolve credential and config placeholders so that
                        // awsCredentials.accessKey / secretKey, awsNodeTemplate,
                        // awsEC2Configs, qaInfraAutomation, etc. get real values.
                        // Without this the cloud credential has literal
                        // ${AWS_ACCESS_KEY_ID} / ${AWS_SECRET_ACCESS_KEY} strings.
                        property.useWithProperties([
                            'AWS_ACCESS_KEY_ID',
                            'AWS_SECRET_ACCESS_KEY'
                        ]) {
                            def resolvedConfig = infrastructure.parseAndSubstituteVars(
                                content: params.CATTLE_TEST_CONFIG,
                                envVars: [
                                    'AWS_ACCESS_KEY_ID':     env.AWS_ACCESS_KEY_ID,
                                    'AWS_SECRET_ACCESS_KEY': env.AWS_SECRET_ACCESS_KEY,
                                    'HOSTNAME_PREFIX':       params.HOSTNAME_PREFIX,
                                    'ADMIN_PASSWORD':        params.RANCHER_ADMIN_PASSWORD ?: 'rancherrocks'
                                ]
                            )
                            writeFile file: "${env.TESTS_DIR}/cattle-config.yaml", text: resolvedConfig.trim() + '\n'
                        }
                    }

                    // Generate admin token via Ansible playbook
                    // TODO: replace with 'make token' once that target is added upstream
                    def cattleConfigPath = "/workspace/${env.TESTS_DIR}/cattle-config.yaml"
                    def workspace = pwd()
                    def tokenTtl = env.RANCHER_TOKEN_TTL ?: '0'
                    def tokenDescription = "jenkins-e2e-${env.BUILD_NUMBER}"

                    // Diagnostic logging to validate env + output path before token generation
                    echo "Token generation context: workspace=${workspace}, config=${cattleConfigPath}"
                    echo "RANCHER_ADMIN_PASSWORD present in env: ${env.RANCHER_ADMIN_PASSWORD ? 'yes' : 'no'}"

                    sh """
                        docker run --rm --platform linux/amd64 \
                            --name generate-token \
                            -e RANCHER_ADMIN_PASSWORD \
                            -e RANCHER_URL=https://${params.HOSTNAME_PREFIX}.qa.rancher.space \
                            -e ANSIBLE_CONFIG=/workspace/${env.INFRA_DIR}/ansible/ansible.cfg \
                            -v ${workspace}:/workspace \
                            -w /workspace/${env.INFRA_DIR}/ansible/rke2/default \
                            rancher-go-test:latest \
                            ansible-playbook -i inventory/inventory.yml /workspace/${env.INFRA_DIR}/ansible/rancher/token/generate-admin-token.yml \
                                -e rancher_cattle_config_file=${cattleConfigPath} \
                                -e rancher_token_ttl=${tokenTtl} \
                                -e rancher_token_description=${tokenDescription} \
                                -e rancher_token_output_format=json \
                                -e rancher_token_output_file=/workspace/rancher-token.json \
                                -e rancher_url=https://${params.HOSTNAME_PREFIX}.qa.rancher.space
                    """

                    def tokenFileExists = fileExists('rancher-token.json')
                    echo "Token file present after generation: ${tokenFileExists}"

                    if (tokenFileExists) {
                        // Redact secret fields from token JSON via Docker container.
                        // Pipeline Utility Steps plugin (readJSON/writeJSON) is not installed,
                        // and python3 is not available on the Jenkins agent host.
                        sh "docker run --rm -v \$(pwd):/workspace -w /workspace rancher-go-test:latest python3 -c \"import json; d=json.load(open('rancher-token.json')); [d.pop(k,None) for k in ('token','bearerToken','accessKey','secretKey','value')]; json.dump(d,open('rancher-token-metadata.json','w'),indent=2)\""
                        archiveArtifacts artifacts: 'rancher-token-metadata.json', fingerprint: true
                        echo 'Archived redacted token metadata: rancher-token-metadata.json'

                        // Infrastructure, Rancher deploy, and admin token all succeeded.
                        // Shared library helpers (infra.*) may have set currentBuild.result to
                        // UNSTABLE/FAILURE via internal catchError() wrappers for non-fatal warnings,
                        // which would cause declarative pipeline to skip downstream test stages.
                        // Reset build result to SUCCESS so Run Test Validations can execute.
                        if (currentBuild.result && currentBuild.result != 'SUCCESS') {
                            echo "Resetting currentBuild.result from '${currentBuild.result}' to 'SUCCESS' — token generation succeeded, allowing test validations to run"
                            currentBuild.result = 'SUCCESS'
                        }
                    } else {
                        echo 'WARNING: rancher-token.json not found after token generation — token may not have been written to workspace'
                    }
                }
            }
        }

        stage('Provision Downstream Cluster') {
            options {
                timeout(time: 15, unit: 'MINUTES')
            }
            when {
                allOf {
                    expression { params.BUILD_DOWNSTREAM_CLUSTER }
                    expression { params.CATTLE_TEST_CONFIG?.trim() }
                }
            }
            steps {
                script {
                    property.useWithProperties([
                        'AWS_ACCESS_KEY_ID',
                        'AWS_SECRET_ACCESS_KEY'
                    ]) {
                        def workspace = pwd()
                        def downstreamModulePath = "${env.INFRA_DIR}/tofu/rancher/cluster"
                        def downstreamTfvarsPath = "${downstreamModulePath}/downstream-cluster.tfvars"
                        def generatedTfvarsPath = "${downstreamModulePath}/generated.tfvars"
                        def cattleConfigPath = "${env.TESTS_DIR}/cattle-config.yaml"

                        // Substitute environment variables in downstream cluster config
                        // Must be inside property.useWithProperties so that
                        // env.AWS_ACCESS_KEY_ID / env.AWS_SECRET_ACCESS_KEY are
                        // populated from Jenkins credentials store.
                        def downstreamConfig = infrastructure.parseAndSubstituteVars(
                            content: params.DOWNSTREAM_CLUSTER_CONFIG,
                            envVars: [
                                'AWS_ACCESS_KEY_ID':     env.AWS_ACCESS_KEY_ID,
                                'AWS_SECRET_ACCESS_KEY': env.AWS_SECRET_ACCESS_KEY,
                                'HOSTNAME_PREFIX':       params.HOSTNAME_PREFIX
                            ]
                        )
                        infrastructure.writeConfig(
                            path:    downstreamTfvarsPath,
                            content: downstreamConfig
                        )

                        // Generate tfvars with Rancher admin token for downstream cluster provisioning.
                        // The token is read from rancher-token.json (written by the previous stage).
                        def adminToken = ''
                        if (fileExists('rancher-token.json')) {
                            adminToken = sh(
                                script: "docker run --rm -v \$(pwd):/workspace -w /workspace rancher-go-test:latest python3 -c \"import json; d=json.load(open('rancher-token.json')); print(d.get('token', d.get('bearerToken', d.get('accessKey', ''))))\"",
                                returnStdout: true
                            ).trim()
                        }
                        if (!adminToken) {
                            echo 'WARNING: No admin token available — using RANCHER_ADMIN_PASSWORD as fallback'
                            adminToken = params.RANCHER_ADMIN_PASSWORD ?: 'rancherrocks'
                        }

                        def rancherUrl = "https://${params.HOSTNAME_PREFIX}.qa.rancher.space"
                        def generatedTfvars = "api_key = \"${adminToken}\"\nfqdn = \"${rancherUrl}\""
                        infrastructure.writeConfig(
                            path:    generatedTfvarsPath,
                            content: generatedTfvars
                        )

                        // Provision downstream cluster through Rancher
                        def tofuApplySuccess = true
                        try {
                            sh """
                                docker run --rm --platform linux/amd64 \
                                    -v ${workspace}:/workspace \
                                    -w /workspace/${downstreamModulePath} \
                                    rancher-go-test:latest \
                                    sh -c '
                                        set -e
                                        tofu init -input=false
                                        tofu apply -auto-approve -var-file=downstream-cluster.tfvars -var-file=generated.tfvars
                                    '
                            """
                        } catch (tofuErr) {
                            tofuApplySuccess = false
                            echo "WARNING: tofu apply failed: ${tofuErr.message}"

                            // ── Diagnostics: query Rancher API for cluster status ──
                            echo '--- Downstream cluster diagnostics ---'
                            sh """
                                docker run --rm --platform linux/amd64 \
                                    -v ${workspace}:/workspace \
                                    -w /workspace/${downstreamModulePath} \
                                    rancher-go-test:latest \
                                    sh -c 'tofu state list 2>/dev/null || true'
                            """

                            // Query Rancher API for cluster conditions
                            writeFile file: 'diag-cluster-status.py', text: """#!/usr/bin/env python3
import urllib.request, json, ssl, sys, os
ctx = ssl.create_default_context()
ctx.check_hostname = False
ctx.verify_mode = ssl.CERT_NONE
try:
    with open("rancher-token.json") as f:
        token_data = json.load(f)
    token = token_data.get("token", token_data.get("bearerToken", ""))
    url = "${rancherUrl}/v3/clusters"
    req = urllib.request.Request(url, headers={"Authorization": "Bearer " + token})
    resp = urllib.request.urlopen(req, context=ctx, timeout=30)
    clusters = json.loads(resp.read()).get("data", [])
    for c in clusters:
        name = c.get("name", "?")
        state = c.get("state", "?")
        print(f"  Cluster: {name}  state: {state}")
        for cond in c.get("conditions", []):
            ctype = cond.get("type", "")
            cstatus = cond.get("status", "")
            cmsg = cond.get("message", cond.get("reason", ""))
            if cstatus == "False" or ctype in ("Provisioned", "Waiting", "Reconciling", "Updated", "Ready"):
                print(f"    {ctype}: {cstatus} - {cmsg}")
    if not clusters:
        print("  No clusters found")
except Exception as e:
    print(f"  Error querying Rancher API: {e}")
"""
                            sh """
                                docker run --rm --platform linux/amd64 \
                                    -v ${workspace}:/workspace \
                                    -w /workspace \
                                    rancher-go-test:latest \
                                    python3 /workspace/diag-cluster-status.py || true
                            """
                            echo '--- End diagnostics ---'
                        }

                        // Get downstream cluster name from tofu output
                        def downstreamClusterName = ''
                        if (tofuApplySuccess) {
                            downstreamClusterName = sh(
                                script: """
                                    docker run --rm --platform linux/amd64 \
                                        -v ${workspace}:/workspace \
                                        -w /workspace/${downstreamModulePath} \
                                        rancher-go-test:latest \
                                        sh -c 'tofu output -raw name'
                                """,
                                returnStdout: true
                            ).trim()
                        } else {
                            // Try to extract cluster name from tofu state even on failure
                            downstreamClusterName = sh(
                                script: """
                                    docker run --rm --platform linux/amd64 \
                                        -v ${workspace}:/workspace \
                                        -w /workspace/${downstreamModulePath} \
                                        rancher-go-test:latest \
                                        sh -c 'tofu output -raw name 2>/dev/null || true'
                                """,
                                returnStdout: true
                            ).trim()
                        }

                        echo "Downstream cluster name: ${downstreamClusterName}"

                        if (!tofuApplySuccess) {
                            error "Downstream cluster provisioning failed. See diagnostics above for details."
                        }

                        // Update cattle-config with downstream cluster name so tests run against it
                        if (downstreamClusterName && fileExists(cattleConfigPath)) {
                            sh "./yq e '.rancher.clusterName = \"${downstreamClusterName}\"' -i ${cattleConfigPath}"
                            echo "Updated cattle-config with clusterName: ${downstreamClusterName}"
                        }
                    } // property.useWithProperties
                }
            }
        }

        stage('Run Test Validations') {
            when {
                expression { params.CATTLE_TEST_CONFIG?.trim() }
            }
            steps {
                script {
                    def workspace = pwd()
                    def cattleConfigPath = "${env.TESTS_DIR}/cattle-config.yaml"
                    def testRunConfig = "${workspace}/testrunconfig.yaml"
                    def qaseBinary = "${workspace}/testrun"

                    // Build qase testrun binary
                    sh """
                        docker run --rm --platform linux/amd64 \
                            -v ${workspace}:/workspace \
                            -w /workspace/${env.TESTS_DIR} \
                            rancher-go-test:latest \
                            sh -c 'env GOOS=linux GOARCH=amd64 CGO_ENABLED=0 go build -o validation/testrun ./validation/pipeline/qase/testrun'
                    """

                    // Start qase test run
                    if (fileExists(qaseBinary)) {
                        sh "${qaseBinary} --startRun=true"
                    }

                    // Read test run ID
                    def testRunID = ''
                    if (fileExists(testRunConfig)) {
                        testRunID = sh(
                            script: "./yq '.id' ${testRunConfig}",
                            returnStdout: true
                        ).trim()
                    }

                    // Update cattle-config with cleanup and desiredflags
                    if (fileExists(cattleConfigPath)) {
                        sh "./yq e '.rancher.cleanup = true' -i ${cattleConfigPath}"
                        sh "./yq e '.flags.desiredflags = \"InstallRancher|Short\"' -i ${cattleConfigPath}"
                    }

                    def configYaml = readFile(file: cattleConfigPath)

                    // Trigger downstream jobs in parallel
                    def jobs = [:]

                    if (params.PROVISIONING_TAGS?.trim()) {
                        def goProvisioningParams = [
                            string(name: 'TIMEOUT', value: params.TEST_TIMEOUT),
                            text(name: 'CONFIG', value: configYaml),
                            string(name: 'REPO', value: params.TESTS_REPO_URL),
                            string(name: 'BRANCH', value: params.TESTS_BRANCH),
                            string(name: 'QASE_TEST_RUN_ID', value: testRunID),
                            string(name: 'TEST_PACKAGE', value: params.TEST_PACKAGE),
                            string(name: 'GOTEST_TESTCASE', value: params.GOTEST_TESTCASE_PROVISIONING),
                            string(name: 'TAGS', value: params.PROVISIONING_TAGS),
                        ]
                        jobs['test-provisioning'] = { build job: params.INDIVIDUAL_JOB, parameters: goProvisioningParams }
                    }

                    if (params.VALIDATION_TEST_TAGS?.trim()) {
                        def goValidationParams = [
                            string(name: 'TIMEOUT', value: params.TEST_TIMEOUT),
                            text(name: 'CONFIG', value: configYaml),
                            string(name: 'REPO', value: params.TESTS_REPO_URL),
                            string(name: 'BRANCH', value: params.TESTS_BRANCH),
                            string(name: 'QASE_TEST_RUN_ID', value: testRunID),
                            string(name: 'TEST_PACKAGE', value: params.TEST_PACKAGE),
                            string(name: 'GOTEST_TESTCASE', value: "${params.GOTEST_TESTCASE_VALIDATION} -p 1"),
                            string(name: 'TAGS', value: params.VALIDATION_TEST_TAGS),
                        ]
                        jobs['test-validation'] = { build job: params.INDIVIDUAL_JOB, parameters: goValidationParams }
                    }

                    if (jobs) {
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            parallel jobs
                        }
                    } else {
                        echo 'No downstream jobs configured — set PROVISIONING_TAGS or VALIDATION_TEST_TAGS to trigger tests.'
                    }

                    // Complete qase test run
                    if (fileExists(qaseBinary)) {
                        sh "${qaseBinary} --startRun=false"
                    }
                }
            }
        }

        stage('Destroy Downstream Cluster') {
            when {
                allOf {
                    expression { params.BUILD_DOWNSTREAM_CLUSTER }
                    expression { params.CATTLE_TEST_CONFIG?.trim() }
                }
            }
            steps {
                script {
                    property.useWithProperties([
                        'AWS_ACCESS_KEY_ID',
                        'AWS_SECRET_ACCESS_KEY'
                    ]) {
                        def workspace = pwd()
                        def downstreamModulePath = "${env.INFRA_DIR}/tofu/rancher/cluster"
                        def downstreamTfvarsPath = "${downstreamModulePath}/downstream-cluster.tfvars"
                        def generatedTfvarsPath = "${downstreamModulePath}/generated.tfvars"

                        // Check if tofu state exists (cluster was provisioned)
                        def stateExists = fileExists("${downstreamModulePath}/terraform.tfstate") ||
                                          fileExists("${downstreamModulePath}/.terraform.lock.hcl")
                        if (stateExists) {
                            echo 'Destroying downstream cluster...'
                            sh """
                                docker run --rm --platform linux/amd64 \
                                    -v ${workspace}:/workspace \
                                    -w /workspace/${downstreamModulePath} \
                                    rancher-go-test:latest \
                                    sh -c '
                                        set -e
                                        tofu init -input=false
                                        tofu destroy -auto-approve -var-file=downstream-cluster.tfvars -var-file=generated.tfvars
                                    '
                            """
                            echo 'Downstream cluster destroyed successfully'
                        } else {
                            echo 'No downstream cluster state found — skipping destroy'
                        }
                    } // property.useWithProperties
                }
            }
        }
    }

    post {
        failure {
            script {
                if (params.DESTROY_ON_FAILURE) {
                    destroyInfrastructure('DESTROY_ON_FAILURE')
                }
            }
        }

        always {
            script {
                if (params.DESTROY_AFTER_TESTS) {
                    destroyInfrastructure('DESTROY_AFTER_TESTS')
                }

                // Docker cleanup
                sh 'docker rmi -f rancher-go-test:latest rancher-infra-tools:latest || true'

                // Sensitive artifact cleanup — shred or remove credentials from workspace
                sh '''
                    set +e

                    cleanup_file() {
                        if [ -f "$1" ]; then
                            if command -v shred >/dev/null 2>&1; then
                                shred -u "$1" || rm -f "$1"
                            else
                                rm -f "$1"
                            fi
                        fi
                    }

                    cleanup_dir() {
                        if [ -d "$1" ]; then
                            find "$1" -type f -exec sh -c '
                                for file do
                                    if command -v shred >/dev/null 2>&1; then
                                        shred -u "$file" || rm -f "$file"
                                    else
                                        rm -f "$file"
                                    fi
                                done
                            ' sh {} +
                            rm -rf "$1"
                        fi
                    }

                    cleanup_file ".go_test_env"
                    cleanup_file "rancher-token.json"
                    cleanup_file "rancher-token-metadata.json"
                    cleanup_file "workspace_name.txt"

                    if [ -n "${INFRA_DIR}" ] && [ -d "${INFRA_DIR}" ]; then
                        find "${INFRA_DIR}" -type f \\( -name 'terraform.tfvars' -o -name '*.pem' -o -name 'id_rsa' -o -name 'id_ed25519' \\) -exec sh -c '
                            for file do
                                if command -v shred >/dev/null 2>&1; then
                                    shred -u "$file" || rm -f "$file"
                                else
                                    rm -f "$file"
                                fi
                            done
                        ' sh {} +
                    fi

                    cleanup_dir ".ssh"
                '''
            }
        }
    }
}
